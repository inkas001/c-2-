#include <stdio.h>
#include <string.h>

struct Supplier {
    char name[20];
    char country[20];
    double local_price;
    double exchange_rate;
    double quality;       
    int lead_time;
    double final_cost;
};

int main() {
    // 1학년 실습 수준을 고려해, 깔끔하게 '2개 업체'를 직접 입력받아 비교하는 구조로 설정합니다.
    struct Supplier list[2]; 

    printf("==================================================================\n");
    printf("         SEMICONDUCTOR SUPPLY CHAIN DATA INPUT SECTION            \n");
    printf("==================================================================\n");

    // 1. 사용자로부터 2개 업체의 데이터를 직접 입력받음
    for (int i = 0; i < 2; i++) {
        printf("\n[ 회사 %d번 정보 입력 ]\n", i + 1);
        
        printf(" -> 회사 이름 (예: A_Corp): ");
        scanf_s("%s", list[i].name, (unsigned int)sizeof(list[i].name));
        
        printf(" -> 수입 국가 (예: Japan, USA, Germany): ");
        scanf_s("%s", list[i].country, (unsigned int)sizeof(list[i].country));
        
        printf(" -> 현지 화폐 기준 단가: ");
        scanf_s("%lf", &list[i].local_price);
        
        printf(" -> 현재 환율 (달러면 1350, 엔화면 100엔당 9.0): ");
        scanf_s("%lf", &list[i].exchange_rate);
        
        printf(" -> 품질 순도 (%% 단위, 예: 99.5): ");
        scanf_s("%lf", &list[i].quality);
        
        printf(" -> 인도 기간 (일 단위, 예: 10): ");
        scanf_s("%sn", &list[i].lead_time); // %d 대신 안정적인 리드타임 정수 입력
        scanf_s("%d", &list[i].lead_time);
    }

    // 2. 전략 모드 선택 단계
    int user_mode = 0;
    printf("\n==================================================================\n");
    printf(" SELECT PURCHASING STRATEGY MODE\n");
    printf(" [1] Cost Optimization (비용 최적화 모드)\n");
    printf(" [2] Quality First     (품질 최우선 모드)\n");
    printf("==================================================================\n");
    printf("Enter mode number (1 or 2): ");
    scanf_s("%d", &user_mode);

    // 3. 연산 가동 (환율 변환 및 14일 초과 리드타임 페널티)
    for (int i = 0; i < 2; i++) {
        if (strcmp(list[i].country, "Japan") == 0 || strcmp(list[i].country, "japan") == 0) {
            list[i].final_cost = list[i].local_price * (list[i].exchange_rate / 100.0);
        } else {
            list[i].final_cost = list[i].local_price * list[i].exchange_rate;
        }

        if (list[i].lead_time > 14) {
            int delay_days = list[i].lead_time - 14;
            list[i].final_cost += (delay_days * 650000.0);
        }
    }

    // 4. 의사결정 매칭 알고리즘
    int best_index = 0;
    if (user_mode == 2) {
        if (list[1].quality > list[0].quality) best_index = 1;
    } else {
        if (list[1].final_cost < list[0].final_cost) best_index = 1;
    }

    // 5. 최종 리포트 출력
    printf("\n==================================================================\n");
    printf("                  SEMICONDUCTOR SUPPLY CHAIN REPORT               \n");
    printf("==================================================================\n");
    for (int i = 0; i < 2; i++) {
        printf("Company: %-10s | Cost: %-11.0f KRW | Quality: %.1f%%\n", 
               list[i].name, list[i].final_cost, list[i].quality);
    }
    printf("------------------------------------------------------------------\n");
    printf(" [FINAL DECISION RESULT]\n");
    printf(" -> 만족하는 최적의 회사는 [%s (%s)] 입니다.\n", list[best_index].name, list[best_index].country);
    printf("==================================================================\n");

    return 0;
}
