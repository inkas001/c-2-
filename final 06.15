#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>
#include <string.h>

struct Supplier {
    char name[20];
    char country[20];
    double local_price;
    double exchange_rate;
    int distance;
    double oil_price;
    double final_cost;
};

int input_supplier_data(struct Supplier list[]) {
    int count = 0;
    char temp_name[20];

    printf("==================================================================\n");
    printf("         SEMICONDUCTOR SUPPLY CHAIN DATA INPUT SECTION            \n");
    printf("==================================================================\n");
    printf(" -> 한 줄에 다음 순서로 입력하세요.\n");
    printf(" -> 업체명 국가 웨이퍼가격 환율 운송거리 현지유가(원화환산)\n");
    printf(" -> 예: TSMC Taiwan 500 43 2200 1400\n");
    printf(" -> 입력을 끝내려면 업체명 자리에 'x'를 입력하세요.\n\n");

    while (count < 30) {
        printf("[ %d번째 업체 정보 입력 ]\n", count + 1);
        printf(" -> 입력: ");

        scanf("%s", temp_name);

        if (strcmp(temp_name, "x") == 0) {
            break;
        }

        strcpy(list[count].name, temp_name);
        scanf("%s %lf %lf %d %lf",
            list[count].country,
            &list[count].local_price,
            &list[count].exchange_rate,
            &list[count].distance,
            &list[count].oil_price);

        printf("------------------------------------------------------------------\n");
        count++;
    }

    return count;
}

void calculate_costs(struct Supplier list[], int count, int quantity) {
    for (int i = 0; i < count; i++) {
        double total_product_price = list[i].local_price * quantity * list[i].exchange_rate;
        double shipping_cost = list[i].distance * list[i].oil_price * 0.3;
        list[i].final_cost = total_product_price + shipping_cost;
    }
}

int main() {
    struct Supplier s_list[30];
    int total_count = 0;
    int order_quantity = 0;

    total_count = input_supplier_data(s_list);

    if (total_count == 0) {
        printf("\n입력된 업체 정보가 없어 프로그램을 종료합니다.\n");
        return 0;
    }

    printf("\n -> 이번 분기에 수입할 웨이퍼 총 개수를 입력하세요: ");
    scanf("%d", &order_quantity);

    calculate_costs(s_list, total_count, order_quantity);

    int best_index = 0;
    for (int i = 1; i < total_count; i++) {
        if (s_list[i].final_cost < s_list[best_index].final_cost) {
            best_index = i;
        }
    }

    printf("\n==================================================================\n");
    printf("                  SEMICONDUCTOR SUPPLY CHAIN REPORT               \n");
    printf("  [ 총 주문 수량: %d 개 | 국가별 유가 리스크 개별 반영 완료 ]\n", order_quantity);
    printf("==================================================================\n");

    for (int i = 0; i < total_count; i++) {
        printf("Company: %-10s | Country: %-7s | Oil: %4.0f 원 | Distance: %-5d km | Total Cost: %-11.0f KRW\n",
            s_list[i].name,
            s_list[i].country,
            s_list[i].oil_price,
            s_list[i].distance,
            s_list[i].final_cost);
    }

    printf("------------------------------------------------------------------\n");
    printf(" [FINAL DECISION RESULT]\n");
    printf(" -> 만족하는 최적의 합리적 회사는 [%s (%s)] 입니다.\n",
        s_list[best_index].name,
        s_list[best_index].country);

    printf(" -> 추천 사유: 해당 국가의 유가 사태(%.0f원/L) 및 운송 거리를 유기적으로 연산하여\n",
        s_list[best_index].oil_price);
    printf("               종합 물류 비용이 가장 경제적인 최저가가 산출되었습니다.\n");
    printf("==================================================================\n");

    return 0;
}
